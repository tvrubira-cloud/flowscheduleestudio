rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Clientes ──────────────────────────────────────────────────────────────
    // Cada usuário só acessa os próprios clientes
    match /clientes/{clienteId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.nome is string
        && request.resource.data.nome.size() >= 2
        && request.resource.data.telefone is string
        && request.resource.data.telefone.size() >= 10;
    }

    // ── Assinaturas ───────────────────────────────────────────────────────────
    // Usuário só lê a própria assinatura, nunca escreve diretamente
    match /assinaturas/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Códigos de ativação ───────────────────────────────────────────────────
    // Qualquer usuário autenticado pode ler e usar um código (a lógica de validação fica no app)
    match /codigos_ativacao/{codigoId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null
        && resource.data.usado == false
        && request.resource.data.usado == true
        && request.resource.data.usadoPor == request.auth.uid;
      allow create, delete: if false; // somente você cria pelo Console
    }

  }
}
