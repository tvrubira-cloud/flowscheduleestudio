# ── Firebase (Frontend) ───────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Firebase Admin (Vercel Function — servidor) ───────────────────────────────
# Gerar em: Firebase Console → Configurações → Contas de serviço → Gerar nova chave privada
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── PagSeguro (Vercel Function — servidor) ────────────────────────────────────
# E-mail da conta PagSeguro e token gerado em: pagseguro.uol.com.br → Preferências → Token
PAGSEGURO_EMAIL=
PAGSEGURO_TOKEN=

# ── Resend (e-mail automático) ────────────────────────────────────────────────
# Criar conta grátis em resend.com → API Keys → Create API Key
RESEND_API_KEY=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Seu e-mail de login — exibe o menu Admin só para você
VITE_ADMIN_EMAIL=seu@email.com
# Senha secreta para proteger a API de envio de códigos (qualquer texto longo)
VITE_ADMIN_SECRET=
ADMIN_SECRET=

# ── Cron ──────────────────────────────────────────────────────────────────────
# Protege o endpoint /api/lembretes — qualquer texto longo e aleatório
CRON_SECRET=
